    float: none;
    margin-right: 8px;
     font-family: 'Noto Sans Bold' !important;
}


}
.mec-toggle-item-col {
    width: 300px;
    border-right: 1px solid #e3e3e3;
    margin-right: 5px !important;
    display: table-cell;
    padding-right: 12px;

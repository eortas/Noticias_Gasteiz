          <h1 class="titular-single-new">El sur de Vitoria tendrá dos centros de salud</h1>

          <!-- AUTOR Y SOCIAL -->
          <div class="mp15 author-new-wrapper">

            <div class="author-new">
                <span class="author vcard" style="padding-right: 3px;"><a href="https://www.gasteizhoy.com/author/mario/" title="Entradas de Mario Lera" rel="author">Mario Lera</a></span><i style="font-size: 4px; vertical-align: middle;" class="fas fa-circle"></i> 

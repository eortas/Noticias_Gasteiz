    background: white;
    color: #191919;
    width: 100%;
    margin: 0 auto;
}

 .mec-event-grid-classic .mec-event-title {
    font-family: 'Noto Sans Bold';
    text-transform: none;
    padding: 0px 3px 15px 3px;
    margin: 10px 0px 0px 0px;
  }



.mec-event-grid-classic .mec-event-content {
